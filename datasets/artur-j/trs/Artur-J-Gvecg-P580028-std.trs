<Sync time="8001.689"/>
vendar je beseda zapisana, #e, po tujem načelu, 
<Sync time="8006.264"/>
#e, svojilne pridevnike pa delamo nekako po, #e, tem, kako smo se priučili tega na besedah v svoji materinščini. 
<Sync time="8016.728"/>
#Eee, v s() trenutnem pravopisu so zadeve urejene tako, 
<Sync time="8021.792"/>
