<Sync time="21.173"/>
#Eee analize, ki so pokazale na 
<Sync time="24.629"/>
ekstremno slabe rezultate 
<Sync time="27.244"/>
telesne zmogljivosti najmlajših. 
<Sync time="29.451"/>
