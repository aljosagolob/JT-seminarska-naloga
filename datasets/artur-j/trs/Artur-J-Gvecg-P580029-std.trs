#E, dala si nam motivacijo za poslušanje naprej, #eee, vesela sem, verjetno tudi marsikdo izmed vas, 
<Sync time="6132.832"/>
#eee, teh informacij, na katere zagotovo, #e, kot uporabnik niti pomislili ne bi. 
