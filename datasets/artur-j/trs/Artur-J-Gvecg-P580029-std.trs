<Sync time="5005.63"/>
Do() 
<Sync time="5006.726"/>
Zdaj pa se preselimo h konkretnemu delu, 
<Sync time="5009.738"/>
#eee, s katerim smo se srečevale pri oblikovanju točkovanja, 
<Sync time="5014.648"/>
#eee, članice projektne skupine. 
<Sync time="5017.26"/>
