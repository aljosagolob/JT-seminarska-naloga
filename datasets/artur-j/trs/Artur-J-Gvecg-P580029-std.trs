<Sync time="6325.551"/>
#eee, dodatno pa smo upoštevali še, da ima eno gradivo lahko več datotek, #e, namreč pripravili smo tudi transkripcije, podnapise, 
<Sync time="6334.373"/>
#e, datoteke s podatki o govorcih in podobno. 
<Sync time="6339.511"/>
#Eee, tukaj vidimo še primer odnosa, #eee, 
<Sync time="6343.078"/>
frazeološke enote in urejanja njenih podatkov. 
