<Sync time="4938.221"/>
seveda za vse svoje skupine, za vse učence, #eee, ki, ki so vključeni, #eem, pod njegovim okriljem. 
<Sync time="4945.837"/>
#Eem, 
<Sync time="4947.532"/>
uporabniki se lahko v e-o(), #eee, e-okolje vključijo, #eee, individualno oziroma uporabljajo individualno, 
<Sync time="4956.542"/>
