<Sync time="495.085"/>
#eee, potem tri pike, 
<Sync time="496.943"/>
#e, pomišljaj in vezaj ter razlikovanje med njima. 
<Sync time="501.291"/>
#E, pri vseh teh ločilih pa je nekaj nalog namenjenih tudi preverjanju stičnosti v zapisu. 
