<Sync time="520.62"/>

<Event desc="breath" type="noise" extent="instantaneous"/>

<Sync time="521.232"/>
#Eee, pri pisanju skupaj in narazen 
<Sync time="524.199"/>
smo se osredotočili na posamezne besedotvorne vrste, 
<Sync time="528.524"/>
#eee, veliko težav smo zaznali pri pisanju členka ne in, #e, glagolov, recimo ne vem, ne bom, 
<Sync time="535.663"/>
#e, tako da smo temu namenili kar precej nalog. 
<Sync time="539.269"/>
In pa, #e, še sklop pa prevzete besede ter 
<Sync time="542.696"/>
težji primeri zapisa, 
<Event desc="breath" type="noise" extent="instantaneous"/>

<Sync time="544.424"/>
te naloge so pa posvečene, 
<Sync time="546.261"/>
