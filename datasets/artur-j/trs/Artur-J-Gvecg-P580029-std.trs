<Sync time="4828.538"/>
#eee, neko pridobi(), se pravi, pridobivanje dosežkov, 
<Sync time="4832.846"/>
#eem, 
<Sync time="4834.422"/>
in jih tudi ne() ne rabimo izkazati nekega znanja, ampak točke največkrat dobimo z urjenjem neke sposobnosti, na primer, da 
<Event desc="breath" type="noise" extent="instantaneous"/>

<Sync time="4843.396"/>
