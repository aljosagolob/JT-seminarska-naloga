#eee, ne bo, dokler ne bo izbral najustreznejšega predloga. 
<Sync time="620.677"/>
#Eem, 
<Sync time="622.643"/>
rada bi vam 
<Sync time="623.559"/>
to, o čemer sem vam zdaj, #e, govorila, tudi ponazorila, 
