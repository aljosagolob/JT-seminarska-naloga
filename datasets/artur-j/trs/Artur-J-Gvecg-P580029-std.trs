<Turn speaker="spk8" startTime="6184.67" endTime="6312.907" fidelity="low">
<Sync time="6184.67"/>
#Eee, torej kot me je že kolegica napovedala, jaz bom predstavil, 
<Sync time="6189.623"/>
#eee, kako smo izkoristili sodobno tehnologijo in računalniške algoritme pri razvoju tega učnega 
<Sync time="6197.28"/>
e-okolja. 
<Sync time="6198.585"/>
#Eee, skušal vam bo, #eee, razložiti, #e, nekako kako poteka vzel(), #e, kako deluje e-okolje, tako da si potem mogoče lažje predstavljali, kaj določene stvari predstavlja. 
<Sync time="6210.444"/>
#Eee, zdaj pri razvoju programske opreme je ključnega pomena dobra zasnova. 
<Sync time="6215.861"/>
#Eee, zavedati se moramo, da računalnik deluje po naših navodilih, 
<Sync time="6220.575"/>
in v zasnovi določimo navodila oziroma pravila, po katerih mora delovati program. 
<Sync time="6226.47"/>
#Eee, programiranje pa je potem samo proces, v katerem zapišemo ta zasnovana navodila 
<Sync time="6232.91"/>
na računalniku razumljiv način, da bo znal izvajati te naše ukaze. 
<Sync time="6239.521"/>
#Eee, zdaj pri razvoju e-okolja smo razdelili, #e, v dva sklopa, najprej smo razvili ta skrbniški del, ki je služil temu, da smo lahko zbrali gradiva, 
<Sync time="6250.316"/>
delali podatke in potem, #e, ustrezno 
<Sync time="6253.366"/>
generirali naloge, ki se pojavljajo v e-okolju. 
<Sync time="6256.558"/>
#Eee, drugi del pa je potem bil namenjen razvoju samega uporabniškega, #eee, 
<Sync time="6261.977"/>
vmesnika, torej aplikacije, ki bo na voljo tudi vam za uporabo. 
<Sync time="6267.732"/>
#Eee, torej govorili smo že nekaj v, v prejšnjih predstavitvah o gradivih, ki smo jih zbirali, torej o naših korpusih Maks, Berta, o slovarjih frazemov, 
<Sync time="6278.302"/>
#e, in tako naprej. #E, da smo lahko vse to zbrali, smo mogli najprej vzpostaviti okolje, v katerem smo ta gradiva zbirali na enem mestu. 
<Sync time="6287.41"/>
#E, tukaj je bilo pomembno, da smo vsa gradiva pretvorili v neki skupni format, da so ti podatki združljivi med sabo. 
<Sync time="6294.842"/>
#E, opremili smo jih tudi z določenimi metapodatki in pa s podatki, ki jih potrebujemo za generiranje nalog in primerov. 
<Sync time="6303.655"/>
#Eee, tukaj vidimo primer, kako poteka nalaganje gradiva 
<Sync time="6308.415"/>
v naš korpus Maks 
<Sync time="6310.584"/>
in izpolnjevanje metapodatkov. 
