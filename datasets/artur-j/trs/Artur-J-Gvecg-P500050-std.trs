#E, ja, tole je kar zanimivo vprašanje glede na to, ko() kot ste že rekla, 
<Sync time="515.953"/>
da je splet poln raznoraznih teorij. 
<Sync time="519.225"/>
#Eem, mislim, da je zelo pomembno, da bolniki s kroničnimi, rizičnimi boleznimi zaupajo, #eem, le preverjenim trditvam in napotkom. 
<Sync time="528.667"/>
#E, sigurno je tudi društvo tisto, ki je dolžno informacije pridobiti in deliti med svoje člane. 
<Sync time="535.408"/>
#Eem, mi smo organizirali Zoom srečanje, 
<Sync time="538.935"/>
kjer sta doktor Salobir in doktor Mlakar odgovorili na vsa vprašanja članov, 
<Sync time="544.296"/>
#e, podali sta tudi najnovejše podatke, potrjene z raziskavami. 
<Sync time="548.863"/>
#E, bolniki se zelo radi udeležijo srečanj, ker sta tudi zdravnici, saj se tekom sproščenega pogovora velikokrat spomniš 
<Sync time="556.867"/>
