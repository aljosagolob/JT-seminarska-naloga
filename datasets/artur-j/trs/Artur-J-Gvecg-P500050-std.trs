<Turn speaker="spk1" startTime="384.395" endTime="451.647" fidelity="high">
<Sync time="384.395"/>
#E, ja, bolezen se je že kar dolgo nazaj začela ozaveščati preko športa. 
<Sync time="391.373"/>
#E, Evropsko združenje je sodelovalo s triatlonom Ironman. 
<Sync time="395.806"/>
#E, zato smo tudi mi, #e, v Sloveniji poiskali naše ironmane, 
<Sync time="401.119"/>
#e, da so ostali brez sape za vse bolnike s pljučno hipertenzijo. 
<Sync time="405.418"/>
#E, združili smo se na neki točki tudi s hrvaškim in srbskim društvom, 
<Sync time="410.909"/>
#e, in imeli v Puli kar devet tekmovalcev v takihle dresih. 
<Sync time="416.802"/>
#Eem, do zdaj smo se že kar trikrat pojavili na puljskem Ironmanu in dvakrat na koprskem. 
<Sync time="423.432"/>
#Eem, imamo pa, #eem, na() tudi širok nabor tekačev, 
<Sync time="428.825"/>
