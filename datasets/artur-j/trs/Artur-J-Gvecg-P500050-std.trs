#Eem, ja, zato vabim vse, ki se soočajo s to boleznijo, 
<Sync time="708.033"/>
#eee, naj se le opogumijo in se nam pridružijo. 
<Sync time="711.3"/>
#E, pišejo nam lahko na mejl, #e, dbph pika Slovenije afna gmail pika com ali pa nam pošljejo 
<Sync time="718.68"/>
zasebno sporočilo na našo Facebook stran 
<Sync time="722.765"/>
afna pljučna hipertenzija. 
