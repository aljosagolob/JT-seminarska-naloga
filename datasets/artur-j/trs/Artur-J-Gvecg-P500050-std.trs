#Eem, naj tule kot zanimivost samo povem, 
<Sync time="607.011"/>
#eem, da sem v vseh teh letih aktivnega sodelovanja v slovenskem in evropskem združenju spoznala samo enega bolnika, 
<Sync time="615.002"/>
#eee, z 
<Sync time="616.609"/>
enako, #e, diagnozo in z enako terapijo kot jaz, 
<Sync time="620.962"/>
