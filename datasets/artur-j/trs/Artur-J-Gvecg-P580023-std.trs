<Background time="801.099" type="shh" level="high"/>
[ime in priimek] 
<Background time="802.242" type="other" level="off"/>
, mlada umetnica mlada, glasbenica če, pomislimo, kje in kaj vse delate, 
<Sync time="808.225"/>
