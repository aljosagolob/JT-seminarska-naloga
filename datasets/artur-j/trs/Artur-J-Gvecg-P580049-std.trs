<Sync time="1540.249"/>
ali očetje ali dedki, babice, 
<Sync time="1543.188"/>
tudi že pradedki, 
<Sync time="1544.622"/>
da se del 
<Sync time="1545.711"/>
teh sredstev, 
<Sync time="1546.943"/>
