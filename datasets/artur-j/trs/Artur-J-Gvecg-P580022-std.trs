</Turn>
<Turn speaker="spk1" startTime="110.116" endTime="150.283" fidelity="high">
<Sync time="110.116"/>
nič pa ni narobe, če je 
<Sync time="112.076"/>
tu vesoljski center. 
<Sync time="113.658"/>
