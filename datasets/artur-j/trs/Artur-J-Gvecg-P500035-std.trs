<Turn speaker="spk1" startTime="305.396" endTime="368.814" fidelity="low">
<Sync time="305.396"/>
Res je sicer, 
<Sync time="306.576"/>
da tudi ti mnogi starostniki, 
<Sync time="309.946"/>
#eee, 
<Sync time="310.726"/>
še močno napredujejo, 
<Sync time="312.749"/>
