<Sync time="339.521"/>
na jezik, 
<Sync time="340.952"/>
#e, in z vsemi temi skupnimi močmi, 
<Sync time="344.926"/>
#eem, kamor ste v resnici vsi povabljeni ali pa smo, če tako rečem, 
<Sync time="350.506"/>
lahko potem, #e, se potrudimo, 
<Sync time="353.808"/>
da so ta zadnja leta 
<Sync time="356.665"/>
lepša 
<Sync time="357.954"/>
in, 
<Sync time="358.859"/>
#e, je potem tudi to poslavljanje, ki nam, nas v tem obdobju na neki način 
<Sync time="363.616"/>
