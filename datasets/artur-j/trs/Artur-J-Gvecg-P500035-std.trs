<Turn speaker="spk1" startTime="269.194" endTime="303.589" fidelity="low">
<Sync time="269.194"/>
Šele ko se namreč zavedaš svojih občutkov 
<Sync time="272.563"/>
in poznaš zgodovino odnosov, 
<Sync time="275.007"/>
nekako lažje sprejmeš 
<Sync time="276.643"/>
