<Turn speaker="spk1" startTime="156.331" endTime="182.49" fidelity="low">
<Sync time="156.331"/>
Če si torej 
<Sync time="157.354"/>
skušamo predstavljati obe skupini, 
<Sync time="160.917"/>
lahko hitro začutimo, 
<Sync time="162.787"/>
kako zelo različno vzdušje vzbudita 
<Sync time="165.834"/>
v našim telesu. 
<Sync time="168.184"/>
In posledično 
<Sync time="169.765"/>
tudi 
<Sync time="170.435"/>
zelo različno odgovornost za skrb 
<Sync time="173.432"/>
ali pa po drugi strani 
<Sync time="175.093"/>
naveličanost, 
<Sync time="176.466"/>
da moraš vedno skrbeti še za nekoga, 
<Sync time="179.32"/>
