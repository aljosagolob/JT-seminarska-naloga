<Turn speaker="spk1" startTime="224.946" endTime="267.661" fidelity="low">
<Sync time="224.946"/>
Iskreno rečeno, 
<Sync time="226.239"/>
obremenjujoča za obe strani. 
<Sync time="228.741"/>
#Eee, vendar tukaj, iskreno rečeno, 
<Sync time="232.593"/>
