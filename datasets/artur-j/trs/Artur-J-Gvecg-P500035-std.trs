<Sync time="321.156"/>
morda jezi, naveličanosti, 
<Sync time="323.666"/>
če čutimo, 
<Sync time="324.885"/>
da je vsaj malo možno, pogovorimo, 
<Sync time="327.895"/>
in potem lahko tudi ti starostniki 
<Sync time="330.439"/>
