<Turn speaker="spk1" startTime="67.024" endTime="82.93" fidelity="low">
<Sync time="67.024"/>
Seveda na to 
<Sync time="68.133"/>
nikakor nimamo enoznačnega odgovora 
<Sync time="71.253"/>
in je vsak primer zase nekako edinstven. 
<Sync time="74.708"/>
Ampak skušajmo pogledati 
<Sync time="76.733"/>
dva vidika, 
<Sync time="77.853"/>
mogoče dve v grobem kategoriji, 
<Sync time="80.458"/>
za kakšnega starostnika sploh gre. 
</Turn>
<Turn startTime="82.93" endTime="84.798">
