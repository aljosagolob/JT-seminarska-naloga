<Sync time="406.588"/>
v službenem okolju, najširši skupnosti ne najdejo zavetja 
<Sync time="410.146"/>
ali pa so zanje ta okolja celo 
<Sync time="412.946"/>
največji vir stisk, iz katerih 
<Sync time="415.022"/>
morajo včasih tudi bežati, 
<Sync time="416.941"/>
