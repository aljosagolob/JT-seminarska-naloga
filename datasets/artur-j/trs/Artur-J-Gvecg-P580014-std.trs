<Sync time="268.433"/>
in imamo okrajno sodišče, 
<Sync time="271.612"/>
#e, v Sloveniji jih je štiriinštirideset, eno od teh je torej v Slovenskih Konjicah, kjer sem 
<Sync time="278.189"/>
