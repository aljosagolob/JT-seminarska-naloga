<Sync time="12898.977"/>
#eee, vijeka do tisoč, #eee, devetsto štirinajstega leta, torej Rusko-slovenski odnosi v dokumentih dvanajstega stoletja do začetka 
<Sync time="12906.473"/>
dvajsetega stoletja, 
<Sync time="12908.122"/>
in urednika zbornik() zbornika Inštituta za slavistiko, torej Inštituta 
<Event desc="unintelligible" type="noise" extent="instantaneous"/>
 slovenika. 
