začela ga bom pa pravzaprav z izjavo doktorja Marjana Št() Šimenca, 
<Sync time="1719.528"/>
#eem, ki nekako na, #eee, 
<Sync time="1721.952"/>
okrogli mizi z naslovom Izobraževanje na daljavo, izkušnje za prihodnost, 
