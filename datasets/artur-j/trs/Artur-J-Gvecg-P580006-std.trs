<Sync time="1365.579"/>
bi si upal reči, 
<Sync time="1366.737"/>
nas u() ne samo, 
<Sync time="1368.378"/>
#e, naučili marsikaj, ampak tudi vzgojili v neke široke, 
<Sync time="1372.111"/>
#e, odkrite ljudi, 
<Sync time="1374.194"/>
