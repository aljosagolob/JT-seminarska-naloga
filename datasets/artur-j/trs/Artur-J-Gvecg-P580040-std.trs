<Turn speaker="spk2" startTime="353.285" endTime="401.831" fidelity="high">
<Sync time="353.285"/>
#Eee, različno od letnega časa seveda, ne. 
<Sync time="356.891"/>
Zjutraj poleti je treba prvo v hlev zgodaj, 
<Sync time="360.957"/>
če je v času šolanja, še otroke pripravim za šolo. 
<Sync time="365.029"/>
Pol 
<Sync time="365.897"/>
hitro nekaj pojesti, na njivo, 
<Sync time="368.357"/>
#e, kosilo, 
<Sync time="369.52"/>
popoldne zopet na njivo ali na travnik, 
<Sync time="372.631"/>
#eee, seveda spet hlev, 
<Sync time="374.747"/>
#eee, velikokrat tudi sam mož postori v hlevu, ker je včasih 
<Sync time="379.738"/>
